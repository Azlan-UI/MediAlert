@page "/appointments/manager"
@attribute [Authorize(Roles = "Patient")]
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Appointments
@using MediAlert.DTOs.Doctors
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Appointment Manager</PageTitle>

<section class="appointments-page">
    <div class="appointments-panel">
        <div class="appointments-header">
            <h1>Manage Appointments</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="status-box @(hasError ? "status-error" : "status-success")">@statusMessage</div>
        }

        <div class="add-appointment-section">
            <h2>Book New Appointment</h2>
            <EditForm Model="requestModel" OnValidSubmit="BookAppointmentAsync" class="appointments-form">
                <DataAnnotationsValidator />

                <div class="field-row">
                    <div class="field-group">
                        <label for="doctorId">Doctor</label>
                        <InputSelect TValue="Guid" id="doctorId" class="form-control" Value="requestModel.DoctorId" ValueChanged="OnDoctorChanged" ValueExpression="() => requestModel.DoctorId">
                            <option value="@Guid.Empty">-- Choose a Doctor --</option>
                            @if (verifiedDoctors != null)
                            {
                                @foreach (var doc in verifiedDoctors)
                                {
                                    <option value="@doc.DoctorId">Dr. @doc.FullName (@doc.Specialization)</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="() => requestModel.DoctorId" />
                    </div>

                    <div class="field-group">
                        <label for="appointmentType">Appointment Type</label>
                        <InputSelect id="appointmentType" class="form-control" @bind-Value="requestModel.AppointmentType">
                            <option value="General Checkup">General Checkup</option>
                            <option value="Video">Video</option>
                            <option value="Follow-up">Follow-up</option>
                            <option value="Urgent">Urgent</option>
                        </InputSelect>
                    </div>
                </div>

                <div class="field-group">
                    <label for="location">Location / URL</label>
                    <InputText id="location" class="form-control" @bind-Value="requestModel.Location" />
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label for="appointmentDate">Select Date</label>
                        <input type="date" id="appointmentDate" class="form-control" value="@(selectedDate?.ToString("yyyy-MM-dd"))" @onchange="OnDateChanged" min="@(DateTime.Now.ToString("yyyy-MM-dd"))" disabled="@(requestModel.DoctorId == Guid.Empty)" />
                    </div>

                    <div class="field-group">
                        <label for="duration">Duration (mins)</label>
                        <InputNumber id="duration" class="form-control" @bind-Value="requestModel.DurationMinutes" @bind-Value:after="OnDurationChanged" />
                    </div>
                </div>

                @if (selectedDate.HasValue)
                {
                    <div class="field-group">
                        <label>Available Slots</label>
                        <div class="slots-container mt-2">
                            @if (isSlotsLoading)
                            {
                                <p class="text-muted">Loading available slots...</p>
                            }
                            else if (availableSlotsForSelectedDate.Count == 0)
                            {
                                <p class="text-muted">No slots available on this date.</p>
                            }
                            else
                            {
                                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                                    @foreach (var slot in availableSlotsForSelectedDate)
                                    {
                                        var isSelected = requestModel.ScheduledDateTime.TimeOfDay == slot && requestModel.ScheduledDateTime.Date == selectedDate.Value.Date;
                                        <button type="button" class="btn @(isSelected ? "btn-primary" : "btn-outline-primary")" style="padding: 6px 12px; border-radius: 6px;" @onclick="() => SelectSlot(slot)">
                                            @DateTime.Today.Add(slot).ToString("h:mm tt")
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                        <ValidationMessage For="() => requestModel.ScheduledDateTime" />
                    </div>
                }
                
                <div class="field-group">
                    <label for="notes">Notes</label>
                    <InputTextArea id="notes" class="form-control" @bind-Value="requestModel.Notes" rows="3" />
                </div>

                <button type="submit" class="btn btn-primary appointments-button" disabled="@isSaving">
                    @(isSaving ? "Booking..." : "Book Appointment")
                </button>
            </EditForm>
        </div>

        <div class="list-section">
            <h2>Your Appointments</h2>
            
            @if (isLoading)
            {
                <div class="loading-state">
                    <p>Loading appointments...</p>
                </div>
            }
            else if (appointments == null || !appointments.Any())
            {
                <div class="empty-state">
                    <p>You have no appointments yet.</p>
                </div>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Date & Time</th>
                            <th>Type</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in appointments.OrderBy(a => a.ScheduledDateTime))
                        {
                            <tr>
                                <td>@appt.ScheduledDateTime.ToLocalTime().ToString("f")</td>
                                <td>@appt.AppointmentType</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(appt.Location) && appt.Location.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a href="@appt.Location" target="_blank" class="btn btn-sm btn-outline-primary">Join Video</a>
                                    }
                                    else
                                    {
                                        @appt.Location
                                    }
                                </td>
                                <td><span class="badge badge-success">@appt.Status</span></td>
                                <td>
                                    @if (appt.Status.Equals("Scheduled", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button class="btn btn-sm btn-danger" @onclick="() => CancelAppointmentAsync(appt.AppointmentId)" disabled="@(isCancellingId == appt.AppointmentId)">
                                            @(isCancellingId == appt.AppointmentId ? "Cancelling..." : "Cancel")
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);

    private readonly CreateAppointmentRequest requestModel = new() {
        ScheduledDateTime = DateTime.Now.AddDays(1).AddHours(1),
        DurationMinutes = 30,
        AppointmentType = "General Checkup"
    };

    private List<AppointmentSummaryResponse>? appointments;
    private List<DoctorSummaryResponse>? verifiedDoctors;
    private List<DoctorAvailabilityResponse>? currentDoctorAvailabilities;
    private List<DateTime>? currentDoctorBookedSlots;
    private DateTime? selectedDate;
    private List<TimeSpan> availableSlotsForSelectedDate = new();
    
    private string? token;
    private string? statusMessage;
    private bool hasError;
    private bool isSaving;
    private bool isLoading = true;
    private bool isSlotsLoading = false;
    private Guid? isCancellingId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
            await LoadAppointmentsAsync();
            await LoadDoctorsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadAppointmentsAsync()
    {
        isLoading = true;
        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/v1/Appointments");
            if (response.IsSuccessStatusCode)
            {
                appointments = await response.Content.ReadFromJsonAsync<List<AppointmentSummaryResponse>>(JsonOptions);
            }
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDoctorsAsync()
    {
        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/v1/Doctors/search");
            if (response.IsSuccessStatusCode)
            {
                verifiedDoctors = await response.Content.ReadFromJsonAsync<List<DoctorSummaryResponse>>(JsonOptions);
            }
        }
        catch (Exception ex)
        {
            ShowError("Failed to load doctors: " + ex.Message);
        }
    }

    private async Task OnDoctorChanged(Guid value)
    {
        requestModel.DoctorId = value;
        if (value != Guid.Empty)
        {
            try
            {
                using var http = CreateHttpClient();
                var response = await http.GetAsync($"api/v1/Doctors/{value}/availability");
                if (response.IsSuccessStatusCode)
                {
                    currentDoctorAvailabilities = await response.Content.ReadFromJsonAsync<List<DoctorAvailabilityResponse>>(JsonOptions);
                }
            }
            catch (Exception ex)
            {
                ShowError("Failed to load doctor availability: " + ex.Message);
            }

            if (selectedDate.HasValue)
            {
                await LoadAvailableSlotsForDateAsync(selectedDate.Value);
            }
        }
        else
        {
            currentDoctorAvailabilities = null;
            availableSlotsForSelectedDate.Clear();
        }
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            await LoadAvailableSlotsForDateAsync(date);
        }
    }

    private void OnDurationChanged()
    {
        if (selectedDate.HasValue)
        {
            GenerateSlots(selectedDate.Value);
        }
    }

    private async Task LoadAvailableSlotsForDateAsync(DateTime date)
    {
        if (requestModel.DoctorId == Guid.Empty || currentDoctorAvailabilities == null) return;

        isSlotsLoading = true;
        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync($"api/v1/Doctors/{requestModel.DoctorId}/booked-slots?date={date:yyyy-MM-dd}");
            if (response.IsSuccessStatusCode)
            {
                currentDoctorBookedSlots = await response.Content.ReadFromJsonAsync<List<DateTime>>(JsonOptions);
            }
            
            GenerateSlots(date);
        }
        catch (Exception ex)
        {
            ShowError("Failed to load booked slots: " + ex.Message);
        }
        finally
        {
            isSlotsLoading = false;
        }
    }

    private void GenerateSlots(DateTime date)
    {
        availableSlotsForSelectedDate.Clear();
        if (currentDoctorAvailabilities == null) return;

        var dayOfWeek = (int)date.DayOfWeek;
        
        var availabilitiesForDate = currentDoctorAvailabilities
            .Where(a => (!a.IsRecurring && a.SpecificDate?.Date == date.Date) ||
                        (a.IsRecurring && a.DayOfWeek == dayOfWeek))
            .ToList();

        foreach (var avail in availabilitiesForDate)
        {
            var start = avail.StartTime.ToTimeSpan();
            var end = avail.EndTime.ToTimeSpan();
            
            var current = start;
            while (current.Add(TimeSpan.FromMinutes(requestModel.DurationMinutes)) <= end)
            {
                var slotDateTimeUtc = new DateTime(date.Year, date.Month, date.Day, current.Hours, current.Minutes, current.Seconds, DateTimeKind.Utc);
                
                if (currentDoctorBookedSlots == null || !currentDoctorBookedSlots.Any(b => b == slotDateTimeUtc))
                {
                    if (slotDateTimeUtc > DateTime.UtcNow)
                    {
                        availableSlotsForSelectedDate.Add(current);
                    }
                }
                
                current = current.Add(TimeSpan.FromMinutes(requestModel.DurationMinutes));
            }
        }
        
        availableSlotsForSelectedDate = availableSlotsForSelectedDate.Distinct().OrderBy(t => t).ToList();
    }

    private void SelectSlot(TimeSpan slot)
    {
        if (selectedDate.HasValue)
        {
            var date = selectedDate.Value.Date;
            requestModel.ScheduledDateTime = new DateTime(date.Year, date.Month, date.Day, slot.Hours, slot.Minutes, slot.Seconds, DateTimeKind.Utc);
        }
    }

    private async Task BookAppointmentAsync()
    {
        if (requestModel.DoctorId == Guid.Empty)
        {
            ShowError("Please select a doctor.");
            return;
        }

        isSaving = true;
        statusMessage = null;
        hasError = false;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.PostAsJsonAsync("api/v1/Appointments", requestModel);

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            statusMessage = "Appointment booked successfully.";
            requestModel.DoctorId = Guid.Empty;
            requestModel.AppointmentType = "";
            requestModel.Location = "";
            requestModel.Notes = "";
            await LoadAppointmentsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CancelAppointmentAsync(Guid appointmentId)
    {
        isCancellingId = appointmentId;
        statusMessage = null;
        hasError = false;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.DeleteAsync($"api/v1/Appointments/{appointmentId}");

            if (response.IsSuccessStatusCode)
            {
                var item = appointments?.FirstOrDefault(a => a.AppointmentId == appointmentId);
                if (item != null) item.Status = "Cancelled";
                statusMessage = "Appointment cancelled successfully.";
            }
            else
            {
                await ShowErrorAsync(response);
            }
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isCancellingId = null;
            StateHasChanged();
        }
    }

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        if (!string.IsNullOrWhiteSpace(token))
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        return http;
    }

    private async Task ShowErrorAsync(HttpResponseMessage response)
    {
        var error = await response.Content.ReadFromJsonAsync<AppointmentsErrorResponse>(JsonOptions);
        ShowError(error?.Message ?? $"Request failed with status {(int)response.StatusCode}.");
    }

    private void ShowError(string message)
    {
        hasError = true;
        statusMessage = message;
    }
}
