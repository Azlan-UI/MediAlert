@page "/appointments/calendar"
@attribute [Authorize(Policy = MediAlert.Constants.AuthorizationPolicies.PremiumPatient)]
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Appointments
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Appointment Calendar</PageTitle>

<section class="calendar-page">
    <div class="calendar-panel">
        <div class="calendar-header">
            <h1>My Calendar</h1>
            <div class="header-actions">
                <button class="btn btn-secondary" @onclick="GoToManager">Manage Appointments</button>
            </div>
        </div>

        <div class="calendar-grid-container">
            <div class="calendar-nav">
                <button class="btn btn-icon" @onclick="PreviousMonth">&lt;</button>
                <h2>@currentMonth.ToString("MMMM yyyy")</h2>
                <button class="btn btn-icon" @onclick="NextMonth">&gt;</button>
            </div>

            <div class="calendar-grid">
                <div class="weekday">Sun</div>
                <div class="weekday">Mon</div>
                <div class="weekday">Tue</div>
                <div class="weekday">Wed</div>
                <div class="weekday">Thu</div>
                <div class="weekday">Fri</div>
                <div class="weekday">Sat</div>

                @for (int i = 0; i < 35; i++)
                {
                    var dayOffset = i - startOffset;
                    var date = currentMonth.AddDays(dayOffset);
                    var isCurrentMonth = date.Month == currentMonth.Month;
                    var isToday = date.Date == DateTime.Today;

                    <div class="calendar-day @(isCurrentMonth ? "" : "other-month") @(isToday ? "today" : "")">
                        <span class="day-number">@date.Day</span>
                        
                        @foreach (var appt in GetAppointmentsForDate(date))
                        {
                            <div class="calendar-event">
                                <span class="time">@appt.ScheduledDateTime.ToString("HH:mm")</span>
                                <span class="title">@appt.AppointmentType</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private DateTime currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private int startOffset;
    private string? token;
    
    private List<AppointmentSummaryResponse> appointments = new();

    protected override void OnInitialized()
    {
        startOffset = (int)currentMonth.DayOfWeek;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
            await LoadAppointmentsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadAppointmentsAsync()
    {
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            if (!string.IsNullOrWhiteSpace(token))
                http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var response = await http.GetAsync("api/v1/Appointments");
            if (response.IsSuccessStatusCode)
            {
                var options = new JsonSerializerOptions(JsonSerializerDefaults.Web);
                appointments = await response.Content.ReadFromJsonAsync<List<AppointmentSummaryResponse>>(options) ?? new();
            }
        }
        catch
        {
            // Ignore error
        }
    }

    private IEnumerable<AppointmentSummaryResponse> GetAppointmentsForDate(DateTime date)
    {
        return appointments.Where(a => a.ScheduledDateTime.Date == date.Date);
    }

    private void GoToManager()
    {
        Navigation.NavigateTo("/appointments/manager");
    }
    
    private void PreviousMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
        startOffset = (int)currentMonth.DayOfWeek;
    }
    
    private void NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
        startOffset = (int)currentMonth.DayOfWeek;
    }
}
