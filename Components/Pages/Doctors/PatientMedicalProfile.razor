@page "/doctor/patients/{PatientId:guid}/profile"
@attribute [Authorize(Roles = "Doctor")]
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Compliance
@using MediAlert.DTOs.PatientMedications
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Patient Medical Profile</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <button class="btn btn-outline-secondary mb-3" @onclick="GoBack">
                <i class="bi bi-arrow-left"></i> Back
            </button>
            <h2 class="fw-bold" style="color: #2c3e50;">Patient Medical Profile</h2>
            <p class="text-muted">Review compliance reports and active medications.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="row g-4">
        <!-- Medications Column -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h4 class="fw-bold mb-0">Active Medications</h4>
                </div>
                <div class="card-body p-4">
                    @if (isLoadingMedicines)
                    {
                        <div class="text-center p-3"><div class="spinner-border text-primary"></div></div>
                    }
                    else if (medicines == null || !medicines.Any())
                    {
                        <p class="text-muted">No active medications found.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var med in medicines)
                            {
                                <div class="list-group-item px-0 py-3">
                                    <div class="d-flex justify-content-between w-100">
                                        <h5 class="mb-1 fw-bold text-primary">@med.DrugName</h5>
                                        <span class="badge bg-light text-dark border">@med.DosageForm</span>
                                    </div>
                                    <p class="mb-1 fw-semibold">@med.DosageStrength — @med.FrequencyPerDay times/day</p>
                                    <small class="text-muted">
                                        From @med.StartDate.ToString("MMM dd, yyyy") 
                                        @(med.EndDate.HasValue ? $"to {med.EndDate.Value.ToString("MMM dd, yyyy")}" : "onward")
                                    </small>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Compliance Report Column -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h4 class="fw-bold mb-0">Monthly Compliance</h4>
                    <div class="d-flex gap-2 mt-3">
                        <select class="form-select form-select-sm w-auto" @bind="selectedMonth">
                            @for (int m = 1; m <= 12; m++)
                            {
                                var label = new DateTime(2000, m, 1).ToString("MMM");
                                <option value="@m">@label</option>
                            }
                        </select>
                        <select class="form-select form-select-sm w-auto" @bind="selectedYear">
                            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-primary" @onclick="LoadReportAsync" disabled="@isLoadingReport">Load</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadPdfAsync" disabled="@isDownloadingPdf">@(isDownloadingPdf ? "PDF..." : "PDF")</button>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (isLoadingReport)
                    {
                        <div class="text-center p-3"><div class="spinner-border text-primary"></div></div>
                    }
                    else if (report == null)
                    {
                        <p class="text-muted">No report data for this period.</p>
                    }
                    else
                    {
                        <div class="text-center mb-4">
                            <h1 class="display-4 fw-bold @GetProgressTextClass(report.OverallCompliancePercentage)">
                                @report.OverallCompliancePercentage%
                            </h1>
                            <p class="text-muted mb-0">Overall Compliance</p>
                        </div>

                        <div class="row text-center g-2 mb-4">
                            <div class="col-4">
                                <div class="p-2 border rounded bg-light">
                                    <div class="fw-bold text-success fs-5">@report.TakenDoses</div>
                                    <small class="text-muted">Taken</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2 border rounded bg-light">
                                    <div class="fw-bold text-danger fs-5">@report.MissedDoses</div>
                                    <small class="text-muted">Missed</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2 border rounded bg-light">
                                    <div class="fw-bold text-secondary fs-5">@report.TotalScheduledDoses</div>
                                    <small class="text-muted">Total</small>
                                </div>
                            </div>
                        </div>

                        @if (report.MedicationSummaries?.Any() == true)
                        {
                            <h6 class="fw-bold">By Medication</h6>
                            <ul class="list-group list-group-flush mb-0">
                                @foreach (var m in report.MedicationSummaries)
                                {
                                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                        @m.DrugName
                                        <span class="badge @GetProgressBgClass(m.CompliancePercentage) rounded-pill">@m.CompliancePercentage%</span>
                                    </li>
                                }
                            </ul>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid PatientId { get; set; }

    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);
    
    private string? token;
    private string? errorMessage;
    
    private bool isLoadingMedicines = true;
    private List<PatientMedicationResponse>? medicines;

    private bool isLoadingReport = true;
    private ComplianceReportResponse? report;
    private int selectedMonth = DateTime.Now.Month;
    private int selectedYear = DateTime.Now.Year;
    private bool isDownloadingPdf;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
            await LoadMedicinesAsync();
            await LoadReportAsync();
            StateHasChanged();
        }
    }

    private async Task LoadMedicinesAsync()
    {
        isLoadingMedicines = true;
        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync($"api/patient/medicines?patientId={PatientId}");
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<PatientMedicationListResponse>(JsonOptions);
                medicines = data?.Medicines;
            }
            else
            {
                errorMessage = "Failed to load medications or access denied.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading medicines: " + ex.Message;
        }
        finally
        {
            isLoadingMedicines = false;
            StateHasChanged();
        }
    }

    private async Task LoadReportAsync()
    {
        isLoadingReport = true;
        report = null;
        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync($"api/v1/Reports/compliance?month={selectedMonth}&year={selectedYear}&patientId={PatientId}");
            if (response.IsSuccessStatusCode)
            {
                report = await response.Content.ReadFromJsonAsync<ComplianceReportResponse>(JsonOptions);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading report: " + ex.Message;
        }
        finally
        {
            isLoadingReport = false;
            StateHasChanged();
        }
    }

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        if (!string.IsNullOrWhiteSpace(token))
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return http;
    }

    private async Task DownloadPdfAsync()
    {
        isDownloadingPdf = true;
        errorMessage = null;
        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync($"api/v1/Reports/monthly/pdf?month={selectedMonth}&year={selectedYear}&patientId={PatientId}");

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Could not generate PDF: " + await response.Content.ReadAsStringAsync();
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);
            var filename = $"ComplianceReport_{selectedYear}_{selectedMonth:D2}.pdf";

            await JS.InvokeVoidAsync("downloadFileFromBase64", base64, filename, "application/pdf");
        }
        catch (Exception ex)
        {
            errorMessage = "Error downloading PDF: " + ex.Message;
        }
        finally
        {
            isDownloadingPdf = false;
        }
    }

    private void GoBack()
    {
        JS.InvokeVoidAsync("history.back");
    }

    private string GetProgressTextClass(decimal pct) => pct switch
    {
        >= 80 => "text-success",
        >= 50 => "text-warning",
        _ => "text-danger"
    };

    private string GetProgressBgClass(decimal pct) => pct switch
    {
        >= 80 => "bg-success",
        >= 50 => "bg-warning",
        _ => "bg-danger"
    };
}
