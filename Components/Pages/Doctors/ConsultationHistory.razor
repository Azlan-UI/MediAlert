@page "/consultations"
@attribute [Authorize(Roles = "Patient")]
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Appointments
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>My Consultations</PageTitle>

<section class="consultations-page">
    <div class="page-header">
        <h1>My Consultations</h1>
        <p>View your upcoming and past appointments.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="status-box status-error">@errorMessage</div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading consultations...</p>
        </div>
    }
    else if (appointments == null || !appointments.Any())
    {
        <div class="empty-state">
            <p>You have no consultations yet.</p>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/doctors")'>Find a Doctor</button>
        </div>
    }
    else
    {
        <div class="tabs">
            <button class="tab @(activeTab == "upcoming" ? "active" : "")" @onclick='() => activeTab = "upcoming"'>Upcoming</button>
            <button class="tab @(activeTab == "past" ? "active" : "")" @onclick='() => activeTab = "past"'>Past</button>
        </div>

        <div class="row g-4 mt-2">
            @foreach (var appt in filteredAppointments)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 position-relative">
                            <span class="badge @(appt.Status.Equals("Scheduled", StringComparison.OrdinalIgnoreCase) ? "bg-primary" : "bg-secondary") position-absolute top-0 end-0 m-3 rounded-pill">@appt.Status</span>
                            
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded p-3 text-center me-3" style="min-width: 65px;">
                                    <div class="fw-bold fs-4 text-primary">@appt.ScheduledDateTime.ToLocalTime().ToString("dd")</div>
                                    <div class="text-uppercase small text-muted fw-semibold">@appt.ScheduledDateTime.ToLocalTime().ToString("MMM")</div>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-dark mb-1">@appt.AppointmentType</h5>
                                    <p class="small text-muted mb-0"><i class="bi bi-clock me-1"></i>@appt.ScheduledDateTime.ToLocalTime().ToString("hh:mm tt")</p>
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrWhiteSpace(appt.Location))
                            {
                                <div class="small text-muted mb-4 p-2 bg-light rounded">
                                    <i class="bi bi-geo-alt me-1"></i> @appt.Location
                                </div>
                            }
                            else
                            {
                                <div class="mb-4"></div>
                            }

                            <div class="d-grid gap-2 mt-auto">
                                @if (appt.Status.Equals("Scheduled", StringComparison.OrdinalIgnoreCase))
                                {
                                    @if (!string.IsNullOrWhiteSpace(appt.Location))
                                    {
                                        @if (hasPremiumAccess)
                                        {
                                            <a class="btn btn-primary rounded-pill" href="@appt.Location" target="_blank"><i class="bi bi-camera-video me-1"></i> Join Call</a>
                                        }
                                        else
                                        {
                                            <a class="btn btn-warning rounded-pill" href="/billing/upgrade"><i class="bi bi-lock-fill me-1"></i> Join Call (Premium)</a>
                                        }
                                    }
                                    <div class="d-flex gap-2 mt-2">
                                        <button class="btn btn-outline-danger rounded-pill w-50" @onclick="() => CancelAppointmentAsync(appt.AppointmentId)"
                                                disabled="@(cancellingId == appt.AppointmentId)">
                                            @(cancellingId == appt.AppointmentId ? "Cancelling…" : "Cancel")
                                        </button>
                                        <button class="btn btn-outline-secondary rounded-pill w-50" @onclick="() => ViewDetails(appt.AppointmentId)">Details</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary rounded-pill w-100" @onclick="() => ViewDetails(appt.AppointmentId)">View Details</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (!filteredAppointments.Any())
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-calendar-x text-muted display-4 opacity-25"></i>
                    <p class="text-muted mt-3">No @activeTab appointments found.</p>
                </div>
            }
        </div>
    }
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);

    private bool isLoading = true;
    private string? token;
    private string? errorMessage;
    private Guid? cancellingId;
    private List<AppointmentSummaryResponse>? appointments;
    private string activeTab = "upcoming";

    private IEnumerable<AppointmentSummaryResponse> filteredAppointments =>
        activeTab == "upcoming"
            ? appointments?.Where(a => a.ScheduledDateTime >= DateTime.Now || a.Status.Equals("Scheduled", StringComparison.OrdinalIgnoreCase)) ?? []
            : appointments?.Where(a => a.ScheduledDateTime < DateTime.Now && !a.Status.Equals("Scheduled", StringComparison.OrdinalIgnoreCase)) ?? [];

    private bool hasPremiumAccess;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
            await LoadAppointmentsAsync();
            await CheckPremiumAccessAsync();
            StateHasChanged();
        }
    }

    private async Task CheckPremiumAccessAsync()
    {
        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/v1/billing/premium-access");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PremiumAccessCheckResult>(JsonOptions);
                hasPremiumAccess = result?.HasPremiumAccess ?? false;
            }
        }
        catch
        {
            hasPremiumAccess = false;
        }
    }

    private class PremiumAccessCheckResult
    {
        public bool HasPremiumAccess { get; set; }
    }

    private async Task LoadAppointmentsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/v1/Appointments");

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to load appointments ({(int)response.StatusCode}).";
                return;
            }

            appointments = await response.Content.ReadFromJsonAsync<List<AppointmentSummaryResponse>>(JsonOptions);
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading appointments: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CancelAppointmentAsync(Guid appointmentId)
    {
        cancellingId = appointmentId;
        errorMessage = null;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.DeleteAsync($"api/v1/Appointments/{appointmentId}");

            if (response.IsSuccessStatusCode)
            {
                var item = appointments?.FirstOrDefault(a => a.AppointmentId == appointmentId);
                if (item != null) item.Status = "Cancelled";
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<AppointmentsErrorResponse>(JsonOptions);
                errorMessage = error?.Message ?? $"Cancel failed ({(int)response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error cancelling appointment: " + ex.Message;
        }
        finally
        {
            cancellingId = null;
        }
    }

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        if (!string.IsNullOrWhiteSpace(token))
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return http;
    }

    private void ViewDetails(Guid consultationId)
    {
        Navigation.NavigateTo($"/consultations/{consultationId}");
    }
}
