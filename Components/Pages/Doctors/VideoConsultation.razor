@page "/consultations/{ConsultationId:guid}/video"
@attribute [Authorize(Policy = MediAlert.Constants.AuthorizationPolicies.PremiumPatient)]
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Video Consultation</PageTitle>

<div class="video-call-container">
    <div class="video-main">
        <!-- Main Video Area (Doctor) -->
        <div class="remote-video">
            @if (isCallActive)
            {
                <div class="video-placeholder doctor-feed">
                    <img src="/images/doctor-placeholder.svg" alt="Doctor" class="fallback-img" />
                    <span class="participant-name">Dr. Jane Doe</span>
                </div>
            }
            else
            {
                <div class="waiting-room">
                    <div class="spinner"></div>
                    <h2>Waiting for Doctor...</h2>
                    <p>Your consultation will begin shortly.</p>
                </div>
            }
        </div>

        <!-- Self Video (Patient) -->
        <div class="local-video @(isCameraOff ? "camera-off" : "")">
            @if (isCameraOff)
            {
                <div class="avatar-initial">Me</div>
            }
            else
            {
                <div class="video-placeholder patient-feed">
                    <span class="camera-active-indicator"></span>
                </div>
            }
        </div>

        <!-- Controls Toolbar -->
        <div class="call-controls">
            <button class="control-btn @(isMuted ? "disabled" : "")" @onclick="ToggleMute" title="@(isMuted ? "Unmute" : "Mute")">
                <i class="icon">@(isMuted ? "🔇" : "🎤")</i>
            </button>
            <button class="control-btn @(isCameraOff ? "disabled" : "")" @onclick="ToggleCamera" title="@(isCameraOff ? "Turn on Camera" : "Turn off Camera")">
                <i class="icon">@(isCameraOff ? "📷 (Off)" : "📷")</i>
            </button>
            <button class="control-btn btn-end-call" @onclick="EndCall" title="End Call">
                <i class="icon">📞</i>
            </button>
        </div>
    </div>
    
    <div class="sidebar">
        <div class="sidebar-header">
            <h3>Consultation Notes</h3>
        </div>
        <div class="notes-area">
            <textarea class="notes-input" placeholder="Type your personal notes here..." @bind="clinicalNotes"></textarea>
            <button class="btn btn-primary mt-2 w-100" @onclick="SaveNotes" disabled="@isSaving">
                @(isSaving ? "Saving..." : "Save Notes")
            </button>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="small mt-2 @(hasError ? "text-danger" : "text-success")">@statusMessage</div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid ConsultationId { get; set; }

    private string clinicalNotes = "";
    private bool isSaving = false;
    private string? statusMessage;
    private bool hasError = false;
    private string? token;

    private bool isCallActive = false;
    private bool isMuted = false;
    private bool isCameraOff = false;

    protected override async Task OnInitializedAsync()
    {
        // Simulate waiting room
        await Task.Delay(3000);
        isCallActive = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
        }
    }

    private void ToggleMute()
    {
        isMuted = !isMuted;
    }

    private void ToggleCamera()
    {
        isCameraOff = !isCameraOff;
    }

    private async Task SaveNotes()
    {
        if (string.IsNullOrWhiteSpace(clinicalNotes))
        {
            statusMessage = "Please enter some notes before saving.";
            hasError = true;
            return;
        }

        isSaving = true;
        statusMessage = null;
        hasError = false;

        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            if (!string.IsNullOrWhiteSpace(token))
                http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            // The content string needs to be properly serialized as JSON for [FromBody] string in the controller.
            var content = new StringContent(JsonSerializer.Serialize(clinicalNotes), System.Text.Encoding.UTF8, "application/json");
            var response = await http.PostAsync($"api/v1/Appointments/{ConsultationId}/notes", content);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Notes saved successfully.";
            }
            else
            {
                statusMessage = "Failed to save notes.";
                hasError = true;
            }
        }
        catch (Exception ex)
        {
            statusMessage = "Error: " + ex.Message;
            hasError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task EndCall()
    {
        if (!string.IsNullOrWhiteSpace(clinicalNotes) && !isSaving)
        {
            await SaveNotes();
        }
        Navigation.NavigateTo("/consultations");
    }
}
