@page "/doctors/{DoctorId:guid}"
@page "/doctors/{DoctorId:guid}/book"
@attribute [Authorize(Policy = MediAlert.Constants.AuthorizationPolicies.PremiumPatient)]
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Doctors
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Doctor Profile</PageTitle>

<section class="profile-page">
    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading doctor profile...</p>
        </div>
    }
    else if (doctor == null)
    {
        <div class="alert alert-error">Doctor not found or an error occurred.</div>
    }
    else
    {
        <div class="profile-container">
            <div class="profile-sidebar">
                <div class="doctor-avatar-large">
                    @doctor.FullName.Substring(0, 1)
                </div>
                <h2>Dr. @doctor.FullName</h2>
                <p class="specialty-text">@doctor.Specialization</p>
                
                @if (doctor.IsVerified)
                {
                    <div class="verified-tag">
                        <span class="icon">✓</span> Verified Professional
                    </div>
                }

                <div class="stats-box">
                    <div class="stat-item">
                        <span class="stat-value">@doctor.ExperienceYears+</span>
                        <span class="stat-label">Years Exp</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <span class="stat-value">@(doctor.RatingAverage?.ToString("0.0") ?? "N/A")</span>
                        <span class="stat-label">Rating</span>
                    </div>
                </div>
            </div>

            <div class="profile-main">
                <div class="booking-section">
                    <h3>Book a Video Consultation</h3>
                    <p class="subtitle">Select your preferred date and time for a video consult.</p>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert @(isSuccess ? "alert-success" : "alert-error")">@statusMessage</div>
                    }

                    <div class="form-group">
                        <label>Preferred Date</label>
                        <input type="date" class="form-control" @bind="bookingDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="form-group">
                        <label>Time Slot</label>
                        <select class="form-control" @bind="bookingTime">
                            <option value="">Select a time...</option>
                            <option value="09:00">09:00 AM</option>
                            <option value="10:00">10:00 AM</option>
                            <option value="11:30">11:30 AM</option>
                            <option value="14:00">02:00 PM</option>
                            <option value="15:30">03:30 PM</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label>Duration</label>
                        <select class="form-control" @bind="bookingDuration">
                            <option value="15">15 Minutes</option>
                            <option value="30">30 Minutes</option>
                            <option value="60">60 Minutes</option>
                        </select>
                    </div>

                    <button class="btn btn-primary btn-block" @onclick="BookConsultationAsync" disabled="@isBooking">
                        @(isBooking ? "Confirming..." : "Confirm Booking")
                    </button>
                </div>
            </div>
        </div>
    }
</section>

@code {
    [Parameter]
    public Guid DoctorId { get; set; }

    private bool isLoading = true;
    private DoctorSummaryResponse? doctor;
    
    // Booking Form
    private DateTime bookingDate = DateTime.Today.AddDays(1);
    private string bookingTime = "";
    private int bookingDuration = 30;
    
    private bool isBooking = false;
    private string? statusMessage;
    private bool isSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDoctorProfileAsync();
    }

    private async Task LoadDoctorProfileAsync()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "medialert_token");
            using var httpClient = new HttpClient();
            httpClient.BaseAddress = new Uri(Navigation.BaseUri);
            httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            // Fetch list and find the doctor locally since there's no single doctor endpoint
            var response = await httpClient.GetAsync("/api/v1/Doctors/search");
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var doctors = JsonSerializer.Deserialize<List<DoctorSummaryResponse>>(content, options);
                doctor = doctors?.FirstOrDefault(d => d.DoctorId == DoctorId);
            }
        }
        catch (Exception)
        {
            // Ignore error for now, use mocked data fallback
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task BookConsultationAsync()
    {
        if (string.IsNullOrEmpty(bookingTime))
        {
            statusMessage = "Please select a time slot.";
            isSuccess = false;
            return;
        }

        isBooking = true;
        statusMessage = null;
        StateHasChanged();

        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "medialert_token");
            using var httpClient = new HttpClient();
            httpClient.BaseAddress = new Uri(Navigation.BaseUri);
            httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var scheduled = bookingDate.Date + TimeSpan.Parse(bookingTime);
            var bookingRequest = new
            {
                DoctorId = DoctorId,
                AppointmentType = "Video Consultation",
                ScheduledDateTime = scheduled,
                DurationMinutes = bookingDuration
            };

            var response = await httpClient.PostAsJsonAsync("/api/v1/Appointments", bookingRequest);
            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Consultation booked successfully!";
                isSuccess = true;
            }
            else
            {
                statusMessage = "Failed to book consultation. Please try again.";
                isSuccess = false;
            }
        }
        catch (Exception)
        {
            statusMessage = "Failed to book consultation.";
            isSuccess = false;
        }
        finally
        {
            isBooking = false;
            StateHasChanged();
            
            if (isSuccess)
            {
                await Task.Delay(2000);
                Navigation.NavigateTo("/consultations");
            }
        }
    }
}
