@page "/patient/calendar"

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold" style="color: #2c3e50;">Unified Calendar</h2>
            <p class="text-muted">Manage your medications, appointments, and refills in one place.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-primary active">Week</button>
                <button type="button" class="btn btn-outline-primary">Month</button>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        <span class="badge rounded-pill bg-primary px-3 py-2" style="cursor: pointer;"><i class="bi bi-pill me-1"></i> Medications</span>
        <span class="badge rounded-pill bg-warning text-dark px-3 py-2" style="cursor: pointer;"><i class="bi bi-exclamation-triangle me-1"></i> Refills</span>
        <span class="badge rounded-pill bg-success px-3 py-2" style="cursor: pointer;"><i class="bi bi-stethoscope me-1"></i> Appointments</span>
        <span class="badge rounded-pill bg-purple text-white px-3 py-2" style="cursor: pointer; background-color: #6f42c1;"><i class="bi bi-camera-video me-1"></i> Consultations</span>
    </div>

    <!-- Calendar Mock View -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0 text-center" style="min-width: 800px;">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3 text-muted fw-normal">Mon 12</th>
                            <th class="py-3 text-muted fw-normal">Tue 13</th>
                            <th class="py-3 fw-bold border-bottom border-primary border-3" style="color: #2c3e50;">Wed 14 (Today)</th>
                            <th class="py-3 text-muted fw-normal">Thu 15</th>
                            <th class="py-3 text-muted fw-normal">Fri 16</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <!-- Mon -->
                            <td class="p-2 align-top" style="height: 150px; width: 20%;">
                                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded mb-2 text-start small border border-primary border-opacity-25" style="cursor: pointer;" @onclick="OpenDrawer">
                                    <strong>8:00 AM</strong><br/>
                                    Lisinopril 10mg
                                </div>
                            </td>
                            <!-- Tue -->
                            <td class="p-2 align-top" style="height: 150px; width: 20%;">
                                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded mb-2 text-start small border border-primary border-opacity-25" style="cursor: pointer;">
                                    <strong>8:00 AM</strong><br/>
                                    Lisinopril 10mg
                                </div>
                                <div class="bg-warning bg-opacity-10 text-dark p-2 rounded mb-2 text-start small border border-warning border-opacity-50" style="cursor: pointer;">
                                    <strong>Refill Alert</strong><br/>
                                    Metformin
                                </div>
                            </td>
                            <!-- Wed (Today) -->
                            <td class="p-2 align-top bg-light" style="height: 150px; width: 20%;">
                                <div class="bg-success bg-opacity-10 text-success p-2 rounded mb-2 text-start small border border-success border-opacity-25 shadow-sm" style="cursor: pointer;">
                                    <strong>2:00 PM</strong><br/>
                                    Dr. Smith (Cardio)
                                </div>
                            </td>
                            <!-- Thu -->
                            <td class="p-2 align-top" style="height: 150px; width: 20%;">
                                <div class="bg-purple bg-opacity-10 p-2 rounded mb-2 text-start small border border-opacity-25" style="cursor: pointer; color: #6f42c1; border-color: #6f42c1;">
                                    <strong>10:30 AM</strong><br/>
                                    Video Consult (Premium)
                                </div>
                            </td>
                            <!-- Fri -->
                            <td class="p-2 align-top" style="height: 150px; width: 20%;">
                                
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Side Drawer Mock (Hidden by default, toggled via state) -->
    @if (isDrawerOpen)
    {
        <div class="position-fixed top-0 end-0 h-100 bg-white shadow-lg p-4" style="width: 400px; z-index: 1050; transition: transform 0.3s ease-in-out;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Event Details</h5>
                <button class="btn-close" @onclick="CloseDrawer"></button>
            </div>
            
            <div class="mb-4">
                <span class="badge bg-primary mb-2">MEDICATION</span>
                <h4>Lisinopril 10mg</h4>
                <p class="text-muted"><i class="bi bi-clock me-2"></i>Scheduled for 8:00 AM</p>
            </div>

            <div class="alert alert-info border-0 bg-primary bg-opacity-10 text-primary">
                <i class="bi bi-info-circle me-2"></i> Take with food or water.
            </div>

            <div class="d-grid gap-2 mt-4">
                <button class="btn btn-primary rounded-pill py-2" @onclick='() => Navigation.NavigateTo("/patient/compliance-test")'>Log Intake</button>
                <button class="btn btn-outline-secondary rounded-pill py-2" @onclick="CloseDrawer">Close</button>
            </div>
        </div>
        
        <!-- Backdrop -->
        <div class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-50" style="z-index: 1040;" @onclick="CloseDrawer"></div>
    }
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool isDrawerOpen = false;

    private void OpenDrawer()
    {
        isDrawerOpen = true;
    }

    private void CloseDrawer()
    {
        isDrawerOpen = false;
    }
}
