@page "/patient/dashboard"
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.PatientMedications
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Patient Dashboard</PageTitle>

<section class="medicine-page">
    <div class="medicine-panel">
        <div class="medicine-header">
            <p class="eyebrow">Central Hub</p>
            <h1>Dashboard</h1>
            <p class="subtitle">Welcome back! Here's your medication overview.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="status-box @(hasError ? "status-error" : "status-success")">@statusMessage</div>
        }

        <div class="dashboard-grid">
            <div class="dashboard-card" @onclick="GoToMedicines">
                <h3>Medications</h3>
                <p class="big-number">@medicineCount</p>
                <p>Active medications</p>
            </div>

            <div class="dashboard-card" @onclick="GoToCompliance">
                <h3>Compliance</h3>
                <p class="big-number">&mdash;</p>
                <p>Overall compliance</p>
            </div>

            <div class="dashboard-card" @onclick="GoToCaregivers">
                <h3>Caregivers</h3>
                <p class="big-number">
                    <span class="bi bi-people-fill"></span>
                </p>
                <p>Manage caregivers</p>
            </div>

            <div class="dashboard-card" @onclick="GoToInteractionChecker">
                <h3>Safety</h3>
                <p class="big-number">
                    <span class="bi bi-shield-check"></span>
                </p>
                <p>Interaction Checker</p>
            </div>
        </div>

        <div class="quick-actions">
            <h2>Quick Actions</h2>
            <div class="action-buttons">
                <button class="btn btn-primary" @onclick="GoToMedicines">
                    Add Medication
                </button>
                <button class="btn btn-secondary" @onclick="GoToCompliance">
                    Log Intake
                </button>
                <button class="btn btn-secondary" @onclick="GoToCaregivers">
                    Manage Caregivers
                </button>
                <button class="btn btn-secondary" @onclick="GoToReports">
                    View Reports
                </button>
                <button class="btn btn-secondary" @onclick="GoToCalendar">
                    Open Calendar
                </button>
            </div>
        </div>
    </div>
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);

    private string? token;
    private string? statusMessage;
    private bool hasError;
    private int medicineCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");

        if (string.IsNullOrWhiteSpace(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadDashboardDataAsync();
        StateHasChanged();
    }

    private async Task LoadDashboardDataAsync()
    {
        try
        {
            using var http = CreateHttpClient();

            var medResponse = await http.GetAsync("api/patient/medicines");
            if (medResponse.IsSuccessStatusCode)
            {
                var meds = await medResponse.Content.ReadFromJsonAsync<PatientMedicationListResponse>(JsonOptions);
                medicineCount = meds?.Medicines.Count ?? 0;
            }
        }
        catch
        {
            statusMessage = "Could not load all dashboard data.";
            hasError = true;
        }
    }

    private void GoToMedicines() => Navigation.NavigateTo("/patient/medicines");
    private void GoToCompliance() => Navigation.NavigateTo("/patient/compliance-test");
    private void GoToCaregivers() => Navigation.NavigateTo("/patient/caregivers");
    private void GoToInteractionChecker() => Navigation.NavigateTo("/patient/interaction-checker");
    private void GoToReports() => Navigation.NavigateTo("/reports/dashboard");
    private void GoToCalendar() => Navigation.NavigateTo("/patient/calendar");

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        if (!string.IsNullOrWhiteSpace(token))
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        return http;
    }
}
