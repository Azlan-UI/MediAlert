@page "/profile"
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Profile
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>My Profile</PageTitle>

<section class="profile-page">
    <div class="profile-panel">
        <div class="profile-header">
            <p class="eyebrow">Account Settings</p>
            <h1>My Profile</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="status-box @(hasError ? "status-error" : "status-success")">@statusMessage</div>
        }

        @if (isLoading)
        {
            <p>Loading profile...</p>
        }
        else
        {
            <EditForm Model="profileForm" OnValidSubmit="UpdateProfileAsync" class="profile-form">
                <DataAnnotationsValidator />

                <div class="field-group">
                    <label for="role">Account Role</label>
                    <input id="role" type="text" class="form-control" value="@profileForm.Role" disabled />
                </div>

                <div class="field-group">
                    <label for="fullName">Full Name</label>
                    <InputText id="fullName" class="form-control" @bind-Value="profileForm.FullName" />
                </div>

                <div class="field-group">
                    <label for="email">Email Address</label>
                    <InputText id="email" type="email" class="form-control" @bind-Value="profileForm.Email" />
                </div>

                <div class="field-group">
                    <label for="phoneNumber">Phone Number (E.164 format, e.g. +1234567890)</label>
                    <InputText id="phoneNumber" type="tel" class="form-control" @bind-Value="profileForm.PhoneNumber" />
                    <ValidationMessage For="@(() => profileForm.PhoneNumber)" class="text-danger mt-1" />
                </div>

                <button type="submit" class="btn btn-primary profile-button" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save Changes")
                </button>
            </EditForm>
        }
    </div>
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);
    private UpdateProfileRequest profileForm = new();
    private string? token;
    private string? statusMessage;
    private bool hasError;
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
        await LoadProfileAsync();
        StateHasChanged();
    }

    private async Task LoadProfileAsync()
    {
        isLoading = true;
        statusMessage = null;
        hasError = false;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/v1/Profile");

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            var profile = await response.Content.ReadFromJsonAsync<UserProfileDto>(JsonOptions);
            if (profile != null)
            {
                profileForm = new UpdateProfileRequest
                {
                    FullName = profile.FullName,
                    Email = profile.Email,
                    PhoneNumber = profile.PhoneNumber,
                    Role = profile.Role // Add a temporary unmapped property just for display
                };
            }
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateProfileAsync()
    {
        isSaving = true;
        statusMessage = null;
        hasError = false;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.PutAsJsonAsync("api/v1/Profile", profileForm);

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            statusMessage = "Profile updated successfully.";
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        if (!string.IsNullOrWhiteSpace(token))
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        return http;
    }

    private async Task ShowErrorAsync(HttpResponseMessage response)
    {
        ShowError($"Request failed with status {(int)response.StatusCode}.");
    }

    private void ShowError(string message)
    {
        hasError = true;
        statusMessage = message;
    }

    public class UpdateProfileRequest : MediAlert.DTOs.Profile.UpdateProfileRequest
    {
        public string Role { get; set; } = string.Empty;
    }
}
