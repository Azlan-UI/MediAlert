@page "/billing/upgrade"
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Billing
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Upgrade Subscription</PageTitle>

<section class="upgrade-page">
    <div class="page-header">
        <h1>Choose Your Plan</h1>
        <p>Unlock premium features to better manage your health and connect with doctors.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">@errorMessage</div>
    }

    <div class="pricing-grid">
        <div class="pricing-card">
            <div class="card-header">
                <h3>Free</h3>
                <div class="price">
                    <span class="currency">$</span><span class="amount">0</span><span class="period">/mo</span>
                </div>
            </div>
            <div class="card-body">
                <ul class="features">
                    <li><i class="icon-check">OK</i> Basic Medication Reminders</li>
                    <li><i class="icon-check">OK</i> Simple Compliance Tracking</li>
                    <li><i class="icon-close">No</i> No Doctor Discovery</li>
                    <li><i class="icon-close">No</i> No Video Consultations</li>
                </ul>
            </div>
            <div class="card-footer">
                <button class="btn btn-outline btn-block" disabled>Included</button>
            </div>
        </div>

        <div class="pricing-card popular">
            <div class="popular-badge">Premium Monthly</div>
            <div class="card-header">
                <h3>Premium</h3>
                <div class="price">
                    <span class="currency">$</span><span class="amount">19.99</span><span class="period">/mo</span>
                </div>
            </div>
            <div class="card-body">
                <ul class="features">
                    <li><i class="icon-check">OK</i> Doctor Discovery</li>
                    <li><i class="icon-check">OK</i> Appointment Booking</li>
                    <li><i class="icon-check">OK</i> Video Consultations</li>
                    <li><i class="icon-check">OK</i> Consultation History</li>
                    <li><i class="icon-check">OK</i> SMS Notifications</li>
                </ul>
            </div>
            <div class="card-footer">
                <button class="btn btn-primary btn-block" @onclick='() => UpgradeTo("Premium")' disabled="@isUpgrading">
                    @(isUpgrading ? "Processing..." : "Upgrade to Premium")
                </button>
            </div>
        </div>
    </div>
</section>

@code {
    private bool isUpgrading;
    private string? errorMessage;

    private async Task UpgradeTo(string tier)
    {
        isUpgrading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "medialert_token");
            using var httpClient = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var request = new CreateSubscriptionCheckoutRequest
            {
                Tier = tier,
                SuccessUrl = Navigation.ToAbsoluteUri("/billing/dashboard?checkout=success&session_id={CHECKOUT_SESSION_ID}").ToString(),
                CancelUrl = Navigation.ToAbsoluteUri("/billing/upgrade?checkout=cancelled").ToString()
            };

            var response = await httpClient.PostAsJsonAsync("/api/v1/Billing/checkout", request);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Could not start Stripe checkout. Please try again.";
                return;
            }

            var sessionResponse = await response.Content.ReadFromJsonAsync<CheckoutSessionResponse>(
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (sessionResponse is null || string.IsNullOrWhiteSpace(sessionResponse.CheckoutUrl))
            {
                errorMessage = "Stripe checkout did not return a redirect URL.";
                return;
            }

            await JS.InvokeVoidAsync("window.location.assign", sessionResponse.CheckoutUrl);
        }
        catch (Exception)
        {
            errorMessage = "An error occurred while creating the checkout session.";
        }
        finally
        {
            isUpgrading = false;
            StateHasChanged();
        }
    }
}
