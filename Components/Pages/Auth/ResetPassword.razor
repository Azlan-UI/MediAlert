@page "/reset-password"
@rendermode InteractiveServer
@using MediAlert.DTOs.Auth
@inject NavigationManager Navigation

<PageTitle>Reset Password</PageTitle>

<section class="login-shell">
    <div class="login-panel">
        <div class="login-header">
            <p class="eyebrow">MediAlert</p>
            <h1>Reset Password</h1>
        </div>

        @if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Token))
        {
            <div class="alert alert-danger">
                Invalid password reset link. Please request a new one.
            </div>
            <div class="mt-4 text-center">
                <a href="/forgot-password" class="text-decoration-none" style="color: #64748b; font-weight: 500;">
                    <i class="bi bi-arrow-left me-1"></i> Back to Forgot Password
                </a>
            </div>
        }
        else if (isSuccess)
        {
            <div class="alert alert-success text-center border-0 shadow-sm" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: 12px; padding: 1.5rem;">
                <i class="bi bi-check-circle-fill mb-2 d-block" style="font-size: 2rem;"></i>
                <h6 class="fw-bold mb-1">Password Reset Successfully</h6>
                <p class="small mb-0">You can now sign in with your new password.</p>
            </div>

            <div class="mt-4 text-center">
                <a href="/login" class="btn btn-primary w-100 fw-bold py-2 rounded-3 shadow-sm">
                    Go to Login
                </a>
            </div>
        }
        else
        {
            <p class="text-muted text-center mb-4" style="font-size: 0.95rem;">
                Create a new password for @Email
            </p>

            <EditForm Model="model" OnValidSubmit="HandleSubmitAsync" class="login-form">
                <DataAnnotationsValidator />

                <div class="field-group">
                    <label for="newPassword">New Password</label>
                    <InputText id="newPassword" type="password" class="form-control" @bind-Value="model.NewPassword" autocomplete="new-password" />
                    <ValidationMessage For="() => model.NewPassword" />
                </div>

                <div class="field-group">
                    <label for="confirmNewPassword">Confirm New Password</label>
                    <InputText id="confirmNewPassword" type="password" class="form-control" @bind-Value="model.ConfirmNewPassword" autocomplete="new-password" />
                    <ValidationMessage For="() => model.ConfirmNewPassword" />
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="login-error" role="alert">@errorMessage</div>
                }

                <button type="submit" class="btn btn-primary login-button mt-2" disabled="@isSubmitting">
                    @(isSubmitting ? "Resetting..." : "Reset Password")
                </button>
            </EditForm>
        }
    </div>
</section>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private ResetPasswordRequest model = new();
    private bool isSubmitting;
    private bool isSuccess;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Email) && !string.IsNullOrEmpty(Token))
        {
            model.Email = Email;
            model.Token = Token;
        }
    }

    private async Task HandleSubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            using var http = new HttpClient
            {
                BaseAddress = new Uri(Navigation.BaseUri)
            };

            var response = await http.PostAsJsonAsync("api/auth/reset-password", model);

            if (response.IsSuccessStatusCode)
            {
                isSuccess = true;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<AuthErrorResponse>();
                errorMessage = error?.Message ?? "Failed to reset password. The link may have expired.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Could not reach the server.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
