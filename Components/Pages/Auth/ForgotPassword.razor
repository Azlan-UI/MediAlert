@page "/forgot-password"
@rendermode InteractiveServer
@using MediAlert.DTOs.Auth
@inject NavigationManager Navigation

<PageTitle>Forgot Password</PageTitle>

<section class="login-shell">
    <div class="login-panel">
        <div class="login-header">
            <p class="eyebrow">MediAlert</p>
            <h1>Forgot Password</h1>
        </div>

        <p class="text-muted text-center mb-4" style="font-size: 0.95rem;">
            Enter your email address and we'll send you a link to reset your password.
        </p>

        @if (isSuccess)
        {
            <div class="alert alert-success text-center border-0 shadow-sm" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: 12px; padding: 1.5rem;">
                <i class="bi bi-envelope-check-fill mb-2 d-block" style="font-size: 2rem;"></i>
                <h6 class="fw-bold mb-1">Email Sent!</h6>
                <p class="small mb-0">Check your inbox for instructions to reset your password.</p>
                
                @if (!string.IsNullOrEmpty(resetLink))
                {
                    <div class="mt-3 p-3 bg-dark bg-opacity-25 rounded-3 text-start">
                        <span class="badge bg-warning text-dark mb-2">Development Mode</span>
                        <p class="small text-muted mb-2">In production, this link would be emailed to the user.</p>
                        <a href="@resetLink" class="btn btn-sm btn-outline-light w-100">Click here to reset password</a>
                    </div>
                }
            </div>

            <div class="mt-4 text-center">
                <a href="/login" class="text-decoration-none" style="color: #64748b; font-weight: 500;">
                    <i class="bi bi-arrow-left me-1"></i> Return to login
                </a>
            </div>
        }
        else
        {
            <EditForm Model="model" OnValidSubmit="HandleSubmitAsync" class="login-form">
                <DataAnnotationsValidator />

                <div class="field-group">
                    <label for="email">Email address</label>
                    <InputText id="email" class="form-control" @bind-Value="model.Email" autocomplete="username" />
                    <ValidationMessage For="() => model.Email" />
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="login-error" role="alert">@errorMessage</div>
                }

                <button type="submit" class="btn btn-primary login-button mt-2" disabled="@isSubmitting">
                    @(isSubmitting ? "Sending..." : "Send Reset Link")
                </button>
                
                <div class="mt-4 text-center">
                    <a href="/login" class="text-decoration-none" style="color: #64748b; font-weight: 500;">
                        <i class="bi bi-arrow-left me-1"></i> Back to login
                    </a>
                </div>
            </EditForm>
        }
    </div>
</section>

@code {
    private ForgotPasswordRequest model = new();
    private bool isSubmitting;
    private bool isSuccess;
    private string? errorMessage;
    private string? resetLink;

    private async Task HandleSubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            using var http = new HttpClient
            {
                BaseAddress = new Uri(Navigation.BaseUri)
            };

            var response = await http.PostAsJsonAsync("api/auth/forgot-password", model);

            if (response.IsSuccessStatusCode)
            {
                isSuccess = true;
                
                // For development, extract the token from the response
                var result = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                if (result != null && result.TryGetValue("token", out var token) && !string.IsNullOrEmpty(token))
                {
                    // Generate the reset link
                    resetLink = $"/reset-password?email={Uri.EscapeDataString(model.Email)}&token={Uri.EscapeDataString(token)}";
                }
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<AuthErrorResponse>();
                errorMessage = error?.Message ?? "Could not process request. Please try again later.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Could not reach the server.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
