@page "/patient/medicines"
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.PatientMedications
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Patient Medicines</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark mb-2">@(editingMedicationId.HasValue ? "Edit Medicine" : "Add Medicine")</h2>
            <p class="text-muted">Manage your active prescriptions and schedules.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @(hasError ? "alert-danger" : "alert-success") border-0 shadow-sm mb-4">
            @statusMessage
        </div>
    }

    <div class="row">
        <!-- Add/Edit Form Column -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <EditForm Model="medicineForm" OnValidSubmit="AddMedicineAsync">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="medicineName" class="form-label fw-semibold">Medicine Name</label>
                            <InputText id="medicineName" class="form-control" @bind-Value="medicineForm.Name" placeholder="e.g., Lisinopril" />
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label for="dosage" class="form-label fw-semibold">Dosage</label>
                                <InputText id="dosage" class="form-control" @bind-Value="medicineForm.Dosage" placeholder="e.g., 10mg" />
                            </div>
                            <div class="col-6">
                                <label for="dosageForm" class="form-label fw-semibold">Form</label>
                                <InputText id="dosageForm" class="form-control" @bind-Value="medicineForm.DosageForm" placeholder="Tablet" />
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label for="frequency" class="form-label fw-semibold">Freq/Day</label>
                                <InputNumber id="frequency" class="form-control" @bind-Value="medicineForm.FrequencyPerDay" />
                            </div>
                            <div class="col-6">
                                <label for="doseTime" class="form-label fw-semibold">First Dose</label>
                                <InputText id="doseTime" type="time" class="form-control" @bind-Value="medicineForm.DoseTime" />
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label for="startDate" class="form-label fw-semibold">Start Date</label>
                                <InputDate id="startDate" class="form-control" @bind-Value="medicineForm.StartDate" />
                            </div>
                            <div class="col-6">
                                <label for="endDate" class="form-label fw-semibold">End Date (Opt)</label>
                                <InputDate id="endDate" class="form-control" @bind-Value="medicineForm.EndDate" />
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-2" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                }
                                @(editingMedicationId.HasValue ? "Update Medicine" : "Save Medicine")
                            </button>
                            @if (editingMedicationId.HasValue)
                            {
                                <button type="button" class="btn btn-light rounded-pill py-2" @onclick="CancelEdit">Cancel</button>
                            }
                        </div>
                    </EditForm>
                </div>
            </div>

            <div class="mt-4 d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary rounded-pill" @onclick="GoToComplianceTest">
                    <i class="bi bi-card-checklist me-1"></i> Intake Logs
                </button>
                <button type="button" class="btn btn-outline-secondary rounded-pill" @onclick="() => LoadMedicinesAsync()" disabled="@isLoading">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Saved Medicines List Column -->
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Saved Medications</h4>
                <span class="badge bg-primary rounded-pill px-3 py-2">@(medicineList?.Medicines.Count ?? 0) Total</span>
            </div>

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (medicineList?.Medicines.Count > 0)
            {
                <div class="row g-3">
                    @foreach (var medicine in medicineList.Medicines)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm rounded-4 position-relative overflow-hidden">
                                <div class="position-absolute top-0 start-0 w-100" style="height: 4px; background: linear-gradient(90deg, #3b82f6, #60a5fa);"></div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title fw-bold text-dark mb-0">@medicine.DrugName</h5>
                                        <span class="badge bg-light text-dark border">@medicine.DosageStrength @medicine.DosageForm</span>
                                    </div>
                                    <p class="text-muted small mb-3">
                                        <i class="bi bi-clock-history me-1"></i> @medicine.FrequencyPerDay time(s) daily
                                    </p>
                                    
                                    <div class="mb-3 d-flex flex-wrap gap-1">
                                        @foreach (var schedule in medicine.DoseSchedules)
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill px-2 py-1">
                                                @schedule.ScheduledTime.ToString("HH:mm")
                                            </span>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-top-0 pt-0 pb-3 d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3" @onclick="() => StartEdit(medicine)">
                                        <i class="bi bi-pencil me-1"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => ConfirmDeactivateAsync(medicine.MedicationId)">
                                        <i class="bi bi-trash me-1"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4 text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-capsule display-1 text-muted opacity-25 mb-3"></i>
                        <h5 class="text-muted">No medications added yet</h5>
                        <p class="text-muted small mb-0">Use the form to add your first prescription.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);

    private readonly MedicineForm medicineForm = new()
    {
        FrequencyPerDay = 1,
        DosageForm = "Tablet",
        DoseTime = "09:00",
        StartDate = DateTime.Today
    };

    private PatientMedicationListResponse? medicineList;
    private string? token;
    private string? statusMessage;
    private bool hasError;
    private bool isLoading;
    private bool isSaving;

    private Guid? editingMedicationId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
        await LoadMedicinesAsync();
        StateHasChanged();
    }

    private void StartEdit(PatientMedicationResponse medicine)
    {
        editingMedicationId = medicine.MedicationId;
        medicineForm.Name = medicine.DrugName;
        medicineForm.Dosage = medicine.DosageStrength;
        medicineForm.DosageForm = medicine.DosageForm;
        medicineForm.FrequencyPerDay = medicine.FrequencyPerDay;
        medicineForm.StartDate = medicine.StartDate.ToDateTime(TimeOnly.MinValue);
        medicineForm.EndDate = medicine.EndDate?.ToDateTime(TimeOnly.MinValue);
        
        var firstDose = medicine.DoseSchedules.FirstOrDefault();
        medicineForm.DoseTime = firstDose != null ? firstDose.ScheduledTime.ToString("HH:mm") : "09:00";
    }

    private void CancelEdit()
    {
        editingMedicationId = null;
        ResetForm();
    }

    private async Task ConfirmDeactivateAsync(Guid medicationId)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this medication? Past records will be kept.");
        if (!confirmed) return;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.DeleteAsync($"api/patient/medicines/{medicationId}");

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            statusMessage = "Medicine deleted successfully.";
            await LoadMedicinesAsync(showLoading: false);
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
    }

    private async Task AddMedicineAsync()
    {
        isSaving = true;
        statusMessage = null;
        hasError = false;

        try
        {
            var request = new UpdatePatientMedicationRequest
            {
                DrugName = medicineForm.Name,
                DosageStrength = medicineForm.Dosage,
                DosageForm = medicineForm.DosageForm,
                FrequencyPerDay = medicineForm.FrequencyPerDay,
                ScheduledTime = medicineForm.DoseTime,
                StartDate = DateOnly.FromDateTime(medicineForm.StartDate),
                EndDate = medicineForm.EndDate is null ? null : DateOnly.FromDateTime(medicineForm.EndDate.Value)
            };

            using var http = CreateHttpClient();
            HttpResponseMessage response;

            if (editingMedicationId.HasValue)
            {
                bool confirmed = await JS.InvokeAsync<bool>("confirm", "Updating this medication will recalculate future dose schedules. Proceed?");
                if (!confirmed)
                {
                    isSaving = false;
                    return;
                }
                response = await http.PutAsJsonAsync($"api/patient/medicines/{editingMedicationId.Value}", request);
            }
            else
            {
                response = await http.PostAsJsonAsync("api/patient/medicines", request);
            }

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            statusMessage = editingMedicationId.HasValue ? "Medicine updated." : "Medicine saved.";
            editingMedicationId = null;
            ResetForm();
            await LoadMedicinesAsync(showLoading: false);
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task LoadMedicinesAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            isLoading = true;
        }

        statusMessage = null;
        hasError = false;

        try
        {
            if (string.IsNullOrWhiteSpace(token))
            {
                token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
            }

            if (string.IsNullOrWhiteSpace(token))
            {
                ShowError("No patient token found. Please log in again.");
                return;
            }

            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/patient/medicines");

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            medicineList = await response.Content.ReadFromJsonAsync<PatientMedicationListResponse>(JsonOptions);
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient
        {
            BaseAddress = new Uri(Navigation.BaseUri)
        };

        if (!string.IsNullOrWhiteSpace(token))
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        return http;
    }

    private async Task ShowErrorAsync(HttpResponseMessage response)
    {
        var error = await response.Content.ReadFromJsonAsync<PatientMedicationErrorResponse>(JsonOptions);
        ShowError(error?.Message ?? $"Request failed with status {(int)response.StatusCode}.");
    }

    private void ShowError(string message)
    {
        hasError = true;
        statusMessage = message;
    }

    private void ResetForm()
    {
        medicineForm.Name = string.Empty;
        medicineForm.Dosage = string.Empty;
        medicineForm.DosageForm = "Tablet";
        medicineForm.FrequencyPerDay = 1;
        medicineForm.DoseTime = "09:00";
        medicineForm.StartDate = DateTime.Today;
        medicineForm.EndDate = null;
    }

    private void GoToComplianceTest()
    {
        Navigation.NavigateTo("/patient/compliance-test");
    }

    private sealed class MedicineForm
    {
        public string Name { get; set; } = string.Empty;
        public string Dosage { get; set; } = string.Empty;
        public string DosageForm { get; set; } = string.Empty;
        public int FrequencyPerDay { get; set; }
        public string DoseTime { get; set; } = string.Empty;
        public DateTime StartDate { get; set; }
        public DateTime? EndDate { get; set; }
    }
}
