@page "/admin/doctors"
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Admin
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Admin - Doctors</PageTitle>

<section class="admin-page">
    <div class="admin-panel">
        <div class="admin-header">
            <button class="btn btn-secondary back-btn" @onclick='() => Navigation.NavigateTo("/admin/dashboard")'>&larr; Back to Dashboard</button>
            <h1>Doctor Verifications</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="status-box @(hasError ? "status-error" : "status-success")">@statusMessage</div>
        }

        @if (isLoading)
        {
            <p>Loading doctors...</p>
        }
        else if (doctors?.Count > 0)
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>License</th>
                        <th>Specialty</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in doctors)
                    {
                        <tr>
                            <td>@doc.FullName<br/><small>@doc.Email</small></td>
                            <td>@doc.LicenseNumber</td>
                            <td>@doc.Specialization</td>
                            <td>
                                @if (doc.VerificationStatus == "Pending")
                                {
                                    <span class="badge badge-pending">Pending</span>
                                }
                                else if (doc.VerificationStatus == "Verified")
                                {
                                    <span class="badge badge-active">Verified</span>
                                }
                                else
                                {
                                    <span class="badge badge-suspended">Rejected</span>
                                }
                            </td>
                            <td>
                                @if (doc.VerificationStatus == "Pending")
                                {
                                    <button class="btn btn-success btn-sm" @onclick='() => VerifyDoctorAsync(doc.DoctorId, "Verified")'>Approve</button>
                                    <button class="btn btn-danger btn-sm" @onclick='() => VerifyDoctorAsync(doc.DoctorId, "Rejected")'>Reject</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No doctors found.</p>
        }
    </div>
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);
    private List<AdminDoctorOverviewDto>? doctors;
    private string? token;
    private string? statusMessage;
    private bool hasError;
    private bool isLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
        await LoadDoctorsAsync();
        StateHasChanged();
    }

    private async Task LoadDoctorsAsync()
    {
        isLoading = true;
        statusMessage = null;
        hasError = false;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/v1/Admin/doctors");

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            doctors = await response.Content.ReadFromJsonAsync<List<AdminDoctorOverviewDto>>(JsonOptions);
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VerifyDoctorAsync(Guid doctorId, string status)
    {
        try
        {
            var req = new VerifyDoctorRequest { VerificationStatus = status };
            using var http = CreateHttpClient();
            var response = await http.PutAsJsonAsync($"api/v1/Admin/doctors/{doctorId}/verify", req);

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            statusMessage = $"Doctor successfully marked as {status}.";
            await LoadDoctorsAsync();
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
    }

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        if (!string.IsNullOrWhiteSpace(token))
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        return http;
    }

    private async Task ShowErrorAsync(HttpResponseMessage response)
    {
        ShowError($"Request failed with status {(int)response.StatusCode}.");
    }

    private void ShowError(string message)
    {
        hasError = true;
        statusMessage = message;
    }
}
