@page "/admin/consultations"
@rendermode InteractiveServer
@using System.Net.Http.Headers
@using System.Text.Json
@using MediAlert.DTOs.Admin
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Admin - Consultations</PageTitle>

<section class="admin-page">
    <div class="admin-panel">
        <div class="admin-header">
            <button class="btn btn-secondary back-btn" @onclick='() => Navigation.NavigateTo("/admin/dashboard")'>&larr; Back to Dashboard</button>
            <h1>Consultation Oversight</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="status-box @(hasError ? "status-error" : "status-success")">@statusMessage</div>
        }

        @if (isLoading)
        {
            <p>Loading consultations...</p>
        }
        else if (consultations?.Count > 0)
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in consultations)
                    {
                        <tr>
                            <td>@c.ScheduledDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@c.PatientName</td>
                            <td>@c.DoctorName</td>
                            <td>@c.Type</td>
                            <td>
                                @if (c.Status == "Completed")
                                {
                                    <span class="badge badge-success">Completed</span>
                                }
                                else if (c.Status == "Cancelled")
                                {
                                    <span class="badge badge-suspended">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge badge-pending">Scheduled</span>
                                }
                            </td>
                            <td>
                                @if (c.Status == "Scheduled")
                                {
                                    <button class="btn btn-danger btn-sm" @onclick='() => CancelConsultationAsync(c.ConsultationId)'>Cancel</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No consultations found.</p>
        }
    </div>
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);
    private List<AdminConsultationOverviewDto>? consultations;
    private string? token;
    private string? statusMessage;
    private bool hasError;
    private bool isLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        token = await JS.InvokeAsync<string?>("localStorage.getItem", "medialert_token");
        await LoadConsultationsAsync();
        StateHasChanged();
    }

    private async Task LoadConsultationsAsync()
    {
        isLoading = true;
        statusMessage = null;
        hasError = false;

        try
        {
            using var http = CreateHttpClient();
            var response = await http.GetAsync("api/v1/Admin/consultations");

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            consultations = await response.Content.ReadFromJsonAsync<List<AdminConsultationOverviewDto>>(JsonOptions);
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CancelConsultationAsync(Guid consultationId)
    {
        try
        {
            using var http = CreateHttpClient();
            var response = await http.PutAsync($"api/v1/Admin/consultations/{consultationId}/cancel", null);

            if (!response.IsSuccessStatusCode)
            {
                await ShowErrorAsync(response);
                return;
            }

            statusMessage = "Consultation successfully cancelled.";
            await LoadConsultationsAsync();
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
    }

    private HttpClient CreateHttpClient()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        if (!string.IsNullOrWhiteSpace(token))
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        return http;
    }

    private async Task ShowErrorAsync(HttpResponseMessage response)
    {
        ShowError($"Request failed with status {(int)response.StatusCode}.");
    }

    private void ShowError(string message)
    {
        hasError = true;
        statusMessage = message;
    }
}
